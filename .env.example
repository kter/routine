# RoutineOps Tracker - Environment Variables Example
# Copy this file to .env and fill in the values

# ── AWS ──────────────────────────────────────────────
AWS_REGION=ap-northeast-1
AWS_PROFILE=dev

# ── Aurora DSQL ──────────────────────────────────────
DB_CLUSTER_ENDPOINT=<aurora-dsql-cluster-endpoint>
DB_NAME=routineops

# ── Cognito ───────────────────────────────────────────
COGNITO_USER_POOL_ID=ap-northeast-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_JWKS_URL=https://cognito-idp.ap-northeast-1.amazonaws.com/<user-pool-id>/.well-known/jwks.json

# ── S3 (evidence storage) ────────────────────────────
EVIDENCE_BUCKET_NAME=routineops-evidence-dev

# ── API ────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173

# ── Frontend ──────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_COGNITO_USER_POOL_ID=ap-northeast-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_REGION=ap-northeast-1
VITE_SENTRY_DSN=<sentry-dsn>
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Backend Monitoring ─────────────────────────────────
SENTRY_DSN=<sentry-dsn>
SENTRY_DSN_PARAMETER_NAME=/routineops/dev/sentry/backend/dsn
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Terraform ─────────────────────────────────────────
TF_STATE_BUCKET=routineops-tfstate
TF_STATE_DYNAMODB_TABLE=routineops-tfstate-lock
SENTRY_FRONTEND_DSN_PARAMETER_NAME=/routineops/dev/sentry/frontend/dsn
TF_VAR_sentry_backend_dsn_parameter_name=/routineops/dev/sentry/backend/dsn
TF_VAR_sentry_traces_sample_rate=0.1
